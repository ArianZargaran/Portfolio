# Copy to .env and fill in. Never commit .env.
# Powers the RAG-backed reply generation on /skills (see app/routes/api.chat.tsx).
# Without these, that endpoint automatically falls back to the static
# keyword-matched replies in app/utils/skills-chat.ts — the site still works.

# Anthropic API key — generates the chat reply from retrieved context.
ANTHROPIC_API_KEY=

# Voyage AI API key — embeds the knowledge base and each incoming question
# for retrieval. https://www.voyageai.com
VOYAGE_API_KEY=
